{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "stream",
  "tasks": {
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "check": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "plan": {
      "dependsOn": ["^typecheck"],
      "cache": false,
      "outputs": []
    },
    "apply": {
      "dependsOn": ["^typecheck"],
      "cache": false,
      "outputs": []
    }
  }
}
