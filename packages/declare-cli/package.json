{
  "name": "@devotta-labs/declare-cli",
  "version": "0.1.0",
  "description": "CLI for @devotta-labs/declare — scaffold DHIS2 metadata projects, run a local DHIS2, and apply schemas.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devotta-labs/dhis2-metadata-as-code.git",
    "directory": "packages/declare-cli"
  },
  "homepage": "https://github.com/devotta-labs/dhis2-metadata-as-code#readme",
  "bugs": {
    "url": "https://github.com/devotta-labs/dhis2-metadata-as-code/issues"
  },
  "keywords": [
    "dhis2",
    "metadata",
    "cli",
    "typescript",
    "docker"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "declare-cli": "./bin/declare-cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "bin",
    "src",
    "templates",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "@devotta-labs/declare": "workspace:*",
    "execa": "^9.5.2",
    "jiti": "^2.4.2",
    "picocolors": "^1.1.1",
    "zod": "^3.23.8"
  }
}
