{
  "name": "@devotta-labs/declare",
  "version": "0.1.0",
  "description": "Type-safe DHIS2 metadata-as-code framework.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devotta-labs/dhis2-metadata-as-code.git",
    "directory": "packages/declare"
  },
  "homepage": "https://github.com/devotta-labs/dhis2-metadata-as-code#readme",
  "bugs": {
    "url": "https://github.com/devotta-labs/dhis2-metadata-as-code/issues"
  },
  "keywords": [
    "dhis2",
    "metadata",
    "typescript",
    "zod",
    "schema"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
